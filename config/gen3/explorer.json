[
  {
    "tabTitle": "Subjects",
    "charts": {
      "experimental_group": {
        "chartType": "fullPie",
        "title": "Experimental Group",
        "label": {
          "show": true
        },
        "showLegendInChart": false
      },
      "ethnicity": {
        "chartType": "horizontalStacked",
        "title": "Ethnicity"
      }
    },
    "filters": {
      "tabs": [
        {
          "title": "Project Selection",
          "fields": ["project_id"]
        },
        {
          "title": "Subjects",
          "fields": [
            "gender",
            "race",
            "ethnicity",
            "age_at_enrollment",
            "experimental_group"
          ],
          "fieldsConfig": {
            "gender": {
              "label": "Sex"
            }
          }
        }
      ]
    },
    "table": {
      "enabled": true,
      "detailsConfig": {
        "panel": "default",
        "mode": "click",
        "idField": "subject_id",
        "title": "Row Details"
      },
      "pageLimit": {
        "limit": 10000
      },
      "fields": [
        "project_id",
        "submitter_id",
        "race",
        "ethnicity",
        "age_at_enrollment",
        "experimental_group"
      ],
      "columns": {
        "submitter_id": {
          "sortable": false
        }
      }
    },
    "dropdowns": {
      "download-table": {
        "title": "Download Table",
        "leftIcon": "gen3:download",
        "rightIcon": "gen3:chevron-down",
        "dropdownItems": [
          {
            "enabled": true,
            "type": "data-json",
            "title": "JSON",
            "leftIcon": "datafile",
            "rightIcon": "download",
            "action": "data-json",
            "actionArgs": {
              "filename": "gen3_datacommon_subjects.json"
            }
          },
          {
            "enabled": true,
            "type": "data-csv",
            "title": "CSV",
            "leftIcon": "datafile",
            "rightIcon": "download",
            "action": "data-csv",
            "actionArgs": {
              "filename": "gen3_datacommon_data_table.csv"
            }
          }
        ]
      }
    },
    "buttons": [
      {
        "enabled": true,
        "type": "manifest",
        "action": "manifest",
        "title": "Download File Manifest for Subjects",
        "leftIcon": "datafile",
        "rightIcon": "download",
        "fileName": "subject_files_manifest.json",
        "actionArgs": {
          "resourceIndexType": "file",
          "resourceIdField": "_subject_id",
          "referenceIdFieldInResourceIndex": "_subject_id",
          "referenceIdFieldInDataIndex": "_file_id",
          "fileFields": ["file_name", "file_size", "md5sum", "object_id"]
        }
      }
    ],
    "loginForDownload": false,
    "guppyConfig": {
      "dataType": "subject",
      "nodeCountTitle": "Subject",
      "fieldMapping": [
        {
          "field": "_samples_count",
          "name": "Samples Count"
        },
        {
          "field": "_imaging_files_count",
          "name": "Imaging Files Count"
        },
        {
          "field": "_unaligned_reads_files_count",
          "name": "Unaligned Reads Count"
        },
        {
          "field": "_aligned_reads_files_count",
          "name": "Aligned Reads Count"
        },
        {
          "field": "_expression_arrays_count",
          "name": "Expression Arrays Count"
        }
      ],
      "manifestMapping": {
        "resourceIndexType": "file",
        "resourceIdField": "object_id",
        "referenceIdFieldInResourceIndex": "subject_id",
        "referenceIdFieldInDataIndex": "subject_id"
      },
      "accessibleFieldCheckList": ["project"],
      "accessibleValidationField": "project"
    }
  },
  {
    "tabTitle": "Data Files",
    "charts": {
      "file_type": {
        "chartType": "stackedBar",
        "title": "File Type"
      },
      "file_format": {
        "chartType": "stackedBar",
        "title": "File Format"
      }
    },
    "filters": {
      "tabs": [
        {
          "title": "File",
          "fields": ["project_id", "data_type", "data_format", "data_category"]
        }
      ]
    },
    "table": {
      "enabled": true,
      "detailsConfig": {
        "panel": "fileDetails",
        "mode": "click",
        "idField": "_file_id",
        "title": "File Details"
      },
      "fields": ["project_id", "file_name", "file_size", "_file_id"]
    },
    "guppyConfig": {
      "dataType": "file",
      "fieldMapping": [
        {
          "field": "file_id",
          "name": "GUID"
        }
      ],
      "nodeCountTitle": "Files",
      "manifestMapping": {
        "resourceIndexType": "subject",
        "resourceIdField": "subject_id",
        "referenceIdFieldInResourceIndex": "object_id",
        "referenceIdFieldInDataIndex": "object_id"
      },
      "accessibleFieldCheckList": ["subject_id"],
      "accessibleValidationField": "subject_id",
      "downloadAccessor": "subject_id"
    },
    "buttons": [
      {
        "enabled": true,
        "type": "manifest",
        "title": "Download File Manifest",
        "leftIcon": "datafile",
        "rightIcon": "download",
        "actionArgs": {
          "filename": "data_table_manifest.csv"
        }
      }
    ],
    "loginForDownload": true
  }
]
