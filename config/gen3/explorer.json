[
  {
    "tabTitle": "Audit Events",
    "charts": {
      "action_name": {
        "chartType": "fullPie",
        "title": "Top Actions",
        "showLegendInChart": true
      },
      "event_source": {
        "chartType": "fullPie",
        "title": "Event Source",
        "showLegendInChart": true
      }
    },
    "filters": {
      "tabs": [
        {
          "title": "Filter",
          "fields": [
            "timestamp",
            "action_name",
            "event_source",
            "result",
            "event_type",
            "cloud_region",
            "cloud_account_id"
          ],
          "fieldsConfig": {
            "timestamp": {
              "label": "Timestamp",
              "type": "exact"
            }
          }
        }
      ]
    },
    "table": {
      "enabled": true,
      "fields": [
        "submitter_id",
        "timestamp",
        "src_ip",
        "user_id",
        "resource",
        "action_name",
        "event_source",
        "result",
        "event_type",
        "cloud_region",
        "cloud_account_id"
      ],
      "columns": {
        "submitter_id": { "sortable": false },
        "user_id": { "sortable": false },
        "resource": { "sortable": false }
      },
      "pageLimit": {
        "limit": 10000
      }
    },
    "dropdowns": {},
    "buttons": [
      {
        "enabled": true,
        "type": "data-json",
        "title": "Export JSON",
        "leftIcon": "datafile",
        "rightIcon": "download",
        "actionArgs": { "filename": "audit_events.json" }
      },
      {
        "enabled": true,
        "type": "data-csv",
        "title": "Export CSV",
        "leftIcon": "datafile",
        "rightIcon": "download",
        "actionArgs": { "filename": "audit_events.csv" }
      },
      {
        "enabled": true,
        "type": "copy-filter-python",
        "title": "Copy Filter as Python",
        "leftIcon": "code",
        "rightIcon": "copy",
        "actionArgs": {}
      }
    ],
    "loginForDownload": false,
    "guppyConfig": {
      "dataType": "audit_event",
      "nodeCountTitle": "Audit Events",
      "fieldMapping": [
        { "field": "submitter_id", "name": "Event ID" },
        { "field": "timestamp", "name": "Timestamp" },
        { "field": "src_ip", "name": "Source IP" },
        { "field": "user_id", "name": "Principal (User/Role)" },
        { "field": "resource", "name": "Target Resource" },
        { "field": "action_name", "name": "API Action" },
        { "field": "event_source", "name": "Log Source" },
        { "field": "result", "name": "Outcome" },
        { "field": "event_type", "name": "Event Type" },
        { "field": "cloud_region", "name": "Region" },
        { "field": "cloud_account_id", "name": "Account ID" },
        { "field": "http_user_agent", "name": "User Agent" }
      ],
      "manifestMapping": {},
      "accessibleFieldCheckList": [],
      "accessibleValidationField": ""
    },
    "crossPivot": {
      "enabled": true,
      "fields": {
        "src_ip": {
          "pivotTo": [{"tab": "WAF", "filterKey": "src_ip"}],
          "contextMenu": "Show this IP in WAF Events"
        },
        "cloud_account_id": {
          "pivotTo": [{"tab": "WAF", "filterKey": "cloud_account_id"}],
          "contextMenu": "Show this Account in WAF Events"
        },
        "action_name": {
          "pivotTo": [{"tab": "WAF", "filterKey": "action"}],
          "contextMenu": "Show related WAF actions"
        }
      }
    }
  },
  {
